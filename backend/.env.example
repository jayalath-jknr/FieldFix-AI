# FieldFix AI — Backend Environment Variables
# Copy this to .env and fill in your values

# ── GCP Configuration ─────────────────────────────────────────────────────────
# Your Google Cloud project ID
GCP_PROJECT_ID=your-gcp-project-id

# GCP region for all services
GCP_REGION=us-central1

# Cloud Storage bucket for knowledge base chunks
GCS_BUCKET_NAME=fieldfix-knowledge-base

# Firestore collection name for fault cases
FIRESTORE_COLLECTION=fault_cases

# ── Gemini Models ─────────────────────────────────────────────────────────────
# Gemini Live model for real-time audio + vision
GEMINI_LIVE_MODEL=gemini-2.5-flash-live

# Gemini model for visual diagnosis (still images)
GEMINI_VISION_MODEL=gemini-2.5-flash

# Embedding model for RAG
EMBEDDING_MODEL=text-embedding-004

# ── Application ───────────────────────────────────────────────────────────────
# Environment: local, staging, production
ENVIRONMENT=local

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# CORS allowed origins (comma-separated for multiple)
CORS_ORIGINS=["http://localhost:5173"]

# Max frame size in bytes (500KB)
MAX_FRAME_SIZE_BYTES=500000

# Camera frame sample interval in milliseconds
FRAME_SAMPLE_INTERVAL_MS=2500
